{
  "name": "Galactic-Spacefarer-Adventure-Aldi",
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "@sap/cds": "^10.0.4"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/cds-types": "^0.18.0",
    "@cap-js/sqlite": "^3",
    "@sap/cds-dk": "^10.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "husky": "^9.1.7",
    "tsx": "^4",
    "typescript": "^6.0.0",
    "cds-plugin-ui5": "^0.17.0"
  },
  "scripts": {
    "postinstall": "rm -rf node_modules/@sap/cds-dk/node_modules/@sap/cds",
    "start": "cds-serve",
    "dev:company": "DEBUG=spacefarer-service,notification-service-mock cds watch --profile development-company",
    "dev": "cds watch",
    "build": "npm run build:cap",
    "build:cap": "cds build",
    "build:ui": "npm --prefix app/spacefarers run build",
    "build:all": "npm run build:cap && npm run build:ui",
    "repl": "cds repl ./",
    "compile:db": "cds compile './db' --to sql",
    "test:cap:log": "CDS_PLUGIN_UI5_ACTIVE=false CDS_ENV=test CDS_TEST_SILENT=false DEBUG=spacefarer-service,notification-service-mock tsx --test test/**/*.test.ts",
    "test:cap": "CDS_PLUGIN_UI5_ACTIVE=false CDS_ENV=test tsx --test test/**/*.test.ts",
    "prepare": "husky"
  },
  "cds": {
    "[development]": {
      "requires": {
        "scheduling": false,
        "db": {
          "kind": "sqlite",
          "credentials": {
            "url": "db.sqlite"
          }
        },
        "auth": {
          "kind": "mocked",
          "users": {
            "space-admin": {
              "password": "admin123",
              "roles": [
                "authenticated-user",
                "SpacefarerAdmin"
              ],
              "attr": {
                "planet": "Orion Belt"
              }
            },
            "space-viewer": {
              "password": "viewer123",
              "roles": [
                "authenticated-user",
                "SpacefarerViewer"
              ],
              "attr": {
                "planet": "Io Relay"
              }
            },
            "*": false
          }
        },
        "notificationService": {
          "impl": "./srv/notification-mock-service.ts"
        }
      }
    },
    "[development-company]": {
      "requires": {
        "scheduling": false,
        "db": {
          "kind": "sqlite",
          "credentials": {
            "url": "db.sqlite"
          }
        },
        "auth": {
          "kind": "dummy"
        },
        "notificationService": {
          "impl": "./srv/notification-mock-service.ts"
        }
      }
    },
    "[test]": {
      "requires": {
        "db": {
          "kind": "sqlite",
          "credentials": {
            "url": ":memory:"
          }
        },
        "auth": {
          "kind": "mocked",
          "users": {
            "space-admin": {
              "password": "admin123",
              "roles": [
                "authenticated-user",
                "SpacefarerAdmin"
              ],
              "attr": {
                "planet": "Orion Belt"
              }
            },
            "space-viewer": {
              "password": "viewer123",
              "roles": [
                "authenticated-user",
                "SpacefarerViewer"
              ],
              "attr": {
                "planet": "Io Relay"
              }
            },
            "*": false
          }
        },
        "notificationService": {
          "impl": "./srv/notification-mock-service.ts"
        }
      }
    },
    "[production]": {
      "requires": {
        "notificationService": {
          "impl": "./srv/notification-production-service.ts"
        }
      }
    }
  },
  "private": true,
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/spacefarers"
  ]
}