{
  "_version": "1.86.0",
  "sap.app": {
    "id": "galactic.spacefarer.adventure.spacefarers",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.29.0",
      "toolsId": "5359c1dd-a1d3-4ed5-aebc-4b47d8bc9434"
    },
    "dataSources": {
      "mainService": {
        "uri": "/spacefarer-service/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.150.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "galactic.spacefarer.adventure.spacefarers.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/spacesuit-color.css"
        }
      ]
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "SpaceFarerList",
          "target": "SpaceFarerList"
        },
        {
          "pattern": "SpaceFarer({key}):?query:",
          "name": "SpaceFarerObjectPage",
          "target": "SpaceFarerObjectPage"
        }
      ],
      "targets": {
        "SpaceFarerList": {
          "type": "Component",
          "id": "SpaceFarerList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/SpaceFarer",
              "variantManagement": "Page",
              "navigation": {
                "SpaceFarer": {
                  "detail": {
                    "route": "SpaceFarerObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  },
                  "columns": {
                    "DataFieldForAnnotation::DataPoint::wormholeNavigationSkill": {
                      "widthIncludingColumnHeader": true
                    },
                    "SpaceSuitColor": {
                      "header": "Spacesuit",
                      "position": {
                        "placement": "After",
                        "anchor": "DataFieldForAnnotation::Chart::stardustCollection"
                      },
                      "template": "galactic.spacefarer.adventure.spacefarers.ext.fragment.SpaceSuitColor",
                      "importance": "Low"
                    }
                  }
                }
              },
              "defaultTemplateAnnotationPath": "com.sap.vocabularies.UI.v1.SelectionPresentationVariant#tableView"
            }
          }
        },
        "SpaceFarerObjectPage": {
          "type": "Component",
          "id": "SpaceFarerObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/SpaceFarer",
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.FieldGroup#GeneratedGroup": {
                  "fields": {
                    "SpaceSuitColor": {
                      "template": "galactic.spacefarer.adventure.spacefarers.ext.fragment.SpaceSuitColor",
                      "position": {
                        "placement": "After",
                        "anchor": "DataField::stardustCollection"
                      },
                      "label": "Space Suit"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
