{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "allowJs": true,
    "types": [
      "node",
      "jest",
      "@cap-js/cds-types"
    ],
    "paths": {
      "#cds-models/*": [
        "./@cds-models/*"
      ]
    }
  }
}