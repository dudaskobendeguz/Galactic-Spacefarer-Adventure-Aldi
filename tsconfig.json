{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "allowJs": true,
    "types": [
      "node",
      "jest"
    ],
    "paths": {
      "#cds-models/*": [
        "./@cds-models/*"
      ]
    }
  },
  "include": [
    "srv/**/*",
    "test/**/*",
    "@cds-models/**/*",
    "node_modules/@cap-js/cds-types/dist/cds-types.d.ts"
  ]
}